# Application
APP_NAME=AutoShortsAI Dashboard
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
ASA_DATABASE_URL=sqlite+aiosqlite:///./data/autoshortsai.db

# CORS
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000","http://localhost:5500"]

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# === مهم للإنتاج ===
# API key لتأمين endpoint الـ report (يُولّد عشوائياً)
# شغّل: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_API_KEY=change-me-to-a-long-random-string

# تفعيل زرع البيانات التجريبية (للتطوير فقط)
ENABLE_SEED=false
